# OnlyQR — combined DEV image: backend (FastAPI) + frontend (Vite) in one container.
# This is a dev convenience so `docker stats` shows a single `onlyqr-codes-dev`.
# Production stays split: the API runs from `Dockerfile` (prod target); the frontend
# is a static build served by nginx on the host (Milestone 3) — no frontend container.
FROM python:3.12-slim

# Node 22 (for Vite) alongside Python.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python deps (layer-cached on requirements.txt).
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Node deps (layer-cached on lockfile). Installed into /app/frontend/node_modules,
# which a named/anonymous volume preserves at runtime (so the host mount can't shadow it).
COPY frontend/package.json frontend/package-lock.json* ./frontend/
RUN cd frontend && npm install

COPY . .

EXPOSE 8000 5173
CMD ["bash", "/app/dev-entrypoint.sh"]
